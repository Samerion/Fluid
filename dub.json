{
  "authors": [
    "Artha"
  ],
  "copyright": "Copyright © 2021, Artha",
  "description": "A flexible UI library: minimal setup, declarative, non-intrusive.",
  "name": "fluid",
  "targetPath": "build",
  "dependencies": {
    "fluid:nodes": {
      "path": "."
    },
    "fluid:backend": {
      "path": "."
    },
    "fluid:font": {
      "path": "."
    }
  },
  "subPackages": [
    "./tour",
    {
      "name": "nodes",
      "targetType": "staticLibrary",
      "targetPath": "build",
      "stringImportPaths": [
        "resources"
      ],
      "excludedSourceFiles": [
        "source/fluid/backend/*.d",
        "source/fluid/font/*.d"
      ]
    },
    {
      "name": "backend",
      "targetType": "staticLibrary",
      "targetPath": "build",
      "sourcePaths": [
        "source/fluid/backend"
      ],
      "dependencies": {
        "fluid:nodes": {
          "path": "."
        }
      },
      "configurations": [
        {
          "name": "raylib",
          "versions": [
            "Fluid_Raylib",
            "Fluid_DefaultRaylib"
          ],
          "libs": [
            "raylib"
          ],
          "dependencies": {
            "raylib-d": "~>5.0"
          }
        },
        {
          "name": "headless",
          "versions": [
            "Fluid_Headless",
            "Fluid_DefaultHeadless"
          ]
        },
        {
          "name": "headless-svg",
          "versions": [
            "Fluid_Headless",
            "Fluid_HeadlessOutput",
            "Fluid_DefaultHeadless"
          ],
          "dependencies": {
            "elemi": "~>1.2.2",
            "arsd-official:image_files": ">=11.3.0 <11.5.2"
          }
        },
        {
          "name": "unittest",
          "versions": [
            "Fluid_Headless",
            "Fluid_DefaultHeadless"
          ]
        },
        {
          "name": "none"
        }
      ]
    },
    {
      "name": "font",
      "targetType": "staticLibrary",
      "targetPath": "build",
      "sourcePaths": [
        "source/fluid/font"
      ],
      "stringImportPaths": [
        "resources"
      ],
      "dependencies": {
        "fluid:nodes": {
          "path": "."
        }
      },
      "configurations": [
        {
          "name": "freetype",
          "versions": [
            "Fluid_Freetype",
            "Fluid_DefaultFreetype"
          ],
          "dependencies": {
            "bindbc-freetype": "~>1.1.1",
            "bindbc-loader": "~>1.1.3"
          }
        },
        {
          "name": "none"
        }
      ]
    }
  ],
  "configurations": [
    {
      "name": "default",
      "targetType": "none"
    },
    {
      "name": "unittest",
      "dependencies": {
        "silly": "~>1.1.1"
      },
      "subConfigurations": {
        "fluid:backend": "headless-svg"
      },
      "sourcePaths": [],
      "sourceFiles": [
        "source/fluid/test.d"
      ],
      "targetType": "library"
    }
  ]
}