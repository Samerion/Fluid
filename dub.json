{
  "authors": [
    "Artha"
  ],
  "copyright": "Copyright © 2021, Artha",
  "description": "A flexible UI library: minimal setup, declarative, non-intrusive.",
  "name": "fluid",
  "targetType": "none",
  "targetPath": "build",
  "sourcePaths": [],
  "dependencies": {
    "fluid:nodes": {
      "path": "."
    },
    "fluid:backend": {
      "path": "."
    },
    "fluid:font": {
      "path": "."
    }
  },
  "lflags-linux": [
    "-L$PACKAGE_DIR/libraries/ubuntu"
  ],
  "lflags-osx": [
    "-L$PACKAGE_DIR/libraries/macos"
  ],
  "lflags-windows": [
    "/LIBPATH:$PACKAGE_DIR/libraries/windows"
  ],
  "subPackages": [
    "./tour",
    {
      "name": "nodes",
      "targetType": "staticLibrary",
      "targetPath": "build",
      "stringImportPaths": [
        "resources"
      ],
      "excludedSourceFiles": [
        "source/fluid/backend/*.d",
        "source/fluid/font/*.d"
      ],
      "configurations": [
        {
          "name": "default"
        },
        {
          "name": "unittest",
          "targetType": "sourceLibrary"
        }
      ]
    },
    {
      "name": "backend",
      "targetType": "staticLibrary",
      "targetPath": "build",
      "sourcePaths": [
        "source/fluid/backend"
      ],
      "dependencies": {
        "fluid:nodes": {
          "path": "."
        }
      },
      "configurations": [
        {
          "name": "raylib",
          "versions": [
            "Fluid_Raylib",
            "Fluid_DefaultRaylib"
          ],
          "libs": [
            "raylib"
          ],
          "dependencies": {
            "raylib-d": "~>5.0"
          }
        },
        {
          "name": "headless",
          "versions": [
            "Fluid_Headless",
            "Fluid_DefaultHeadless"
          ]
        },
        {
          "name": "headless-svg",
          "versions": [
            "Fluid_Headless",
            "Fluid_HeadlessOutput",
            "Fluid_DefaultHeadless"
          ],
          "dependencies": {
            "elemi": "~>1.2.2",
            "arsd-official:image_files": ">=11.3.0 <11.5.2"
          }
        },
        {
          "name": "unittest",
          "targetType": "sourceLibrary",
          "versions": [
            "Fluid_Headless",
            "Fluid_HeadlessOutput",
            "Fluid_DefaultHeadless"
          ],
          "dependencies": {
            "elemi": "~>1.2.2",
            "arsd-official:image_files": ">=11.3.0 <11.5.2"
          }
        },
        {
          "name": "none"
        }
      ]
    },
    {
      "name": "font",
      "targetType": "staticLibrary",
      "targetPath": "build",
      "sourcePaths": [
        "source/fluid/font"
      ],
      "stringImportPaths": [
        "resources"
      ],
      "dependencies": {
        "fluid:nodes": {
          "path": "."
        }
      },
      "configurations": [
        {
          "name": "freetype",
          "versions": [
            "Fluid_Freetype",
            "Fluid_DefaultFreetype"
          ],
          "dependencies": {
            "bindbc-freetype": "~>1.1.1",
            "bindbc-loader": "~>1.1.3"
          }
        },
        {
          "name": "unittest",
          "targetType": "sourceLibrary",
          "versions": [
            "Fluid_Freetype",
            "Fluid_DefaultFreetype"
          ],
          "dependencies": {
            "bindbc-freetype": "~>1.1.1",
            "bindbc-loader": "~>1.1.3"
          }
        },
        {
          "name": "none"
        }
      ]
    },
    {
      "name": "module-view",
      "sourceFiles": [
        "source/fluid/module_view.d"
      ],
      "sourcePaths": [],
      "targetPath": "build",
      "targetType": "library",
      "versions": [
        "Fluid_ModuleView"
      ],
      "dflags-posix-dmd": [
        "-defaultlib=libphobos2.so"
      ],
      "dflags-ldc": [
        "--link-defaultlib-shared"
      ],
      "dependencies": {
        "fluid": {
          "path": "."
        },
        "fluid-tree-sitter": "~>0.1.6",
        "fluid-tree-sitter:d": "~>0.1.6"
      },
      "configurations": [
        {
          "name": "default"
        },
        {
          "name": "unittest",
          "subConfigurations": {
            "fluid:backend": "headless-svg"
          }
        }
      ]
    }
  ],
  "configurations": [
    {
      "name": "default"
    },
    {
      "name": "unittest",
      "dependencies": {
        "silly": "~>1.1.1"
      },
      "subConfigurations": {
        "fluid:backend": "unittest",
        "fluid:nodes": "unittest",
        "fluid:font": "unittest"
      },
      "sourcePaths": [
        "source"
      ],
      "targetType": "library"
    }
  ]
}
